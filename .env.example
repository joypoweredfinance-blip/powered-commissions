# Local development: leave TURSO_DATABASE_URL unset to use a local file DB at db/local.db
# Production (Render): set both to your free Turso database's values (Turso dashboard > your DB > "Connect")
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# Joy's admin login email — the account seeded on first boot
ADMIN_EMAIL=joy.powered.finance@gmail.com

PORT=3000
NODE_ENV=development
